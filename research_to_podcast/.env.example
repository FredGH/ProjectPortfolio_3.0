ANTHROPIC_API_KEY=the_key

# ---------------------------------------------------------------------------
# Guardrails — token consumption
# ---------------------------------------------------------------------------
# Hard ceiling on tokens each LLM agent may generate per call.
# Researcher and Analyst are kept lower; Scriptwriter needs more headroom.
MAX_TOKENS_RESEARCHER=2048
MAX_TOKENS_ANALYST=2048
MAX_TOKENS_SCRIPTWRITER=3000

# Maximum characters of previous-step output passed as context to the next agent.
# Prevents runaway input token counts. (~6000 chars ≈ 1500 tokens)
MAX_CONTEXT_CHARS=6000

# Maximum characters allowed in the topic input field.
MAX_TOPIC_LENGTH=200

# Warn in the UI when cumulative session tokens exceed this threshold.
TOKEN_WARN_THRESHOLD=8000

# Seconds to pause between LLM agent calls to stay within per-minute token limits.
# 65s is safe for the free/low tier (30k input tok/min). Lower this on higher plans.
AGENT_DELAY_SECONDS=65

# ---------------------------------------------------------------------------
# Pricing (USD per million tokens) — used for cost display in the UI.
# Defaults match claude-sonnet-4-6 as of 2025-04.
# Update these if Anthropic changes pricing.
# ---------------------------------------------------------------------------
PRICE_INPUT_PER_MTOK=3.00
PRICE_OUTPUT_PER_MTOK=15.00
