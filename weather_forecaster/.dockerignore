# Version control
.git/

# Python artefacts
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Test artefacts
.pytest_cache/

# Generated data (mounted as volume at runtime)
data/

# Secrets — never bake into the image
.env

# IDE / OS
.vscode/
.DS_Store

# dbt generated artefacts (mounted as volumes at runtime)
dbt/target/
dbt/logs/

# Dagster runtime state — generated at runtime, never baked into images
dagster_home/logs/
dagster_home/storage/
dagster_home/schedules/
dagster_home/history/

# Claude and Kilocode tooling (not needed in container)
.claude/
.kilocode/
